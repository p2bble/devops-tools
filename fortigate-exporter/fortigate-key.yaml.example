# =============================================================================
# FortiGate Exporter API 인증 설정 예시
# 실제 파일명: fortigate-key.yaml (.gitignore에 포함됨)
# =============================================================================
#
# ⚠️  주의사항:
#   1. 최상위 키는 반드시 FortiGate URL을 직접 사용 (targets: 래퍼 금지)
#      targets: 래퍼를 쓰면 "Loaded 1 API keys" 후 "no API authentication registered" 오류
#
#   2. Switch/ManagedSwitch probe 반드시 exclude
#      포함 시 FortiSwitch의 빈 switch_name 라벨로 중복 메트릭 1400+건 발생
#
#   3. FortiGate admin 포트 확인 필요 (기본값과 다를 수 있음)
#      FortiGate CLI: config system global → get admin-sport
#
#   4. 대상 인터페이스에 HTTPS allowaccess 필요
#      FortiGate GUI → Network → Interfaces → Edit → Administrative Access → HTTPS 체크
#
# FortiGate에서 API 토큰 발급:
#   FortiGate GUI → System → Administrators → Create New → REST API Admin
#   → Trusted Hosts: 모니터링 서버 IP/32, Comments: prometheus-exporter
# =============================================================================

'https://172.19.100.1:38879':
  token: 'YOUR_API_TOKEN_HERE'
  probes:
    exclude:
      - Switch/ManagedSwitch

'https://172.18.100.1:38879':
  token: 'YOUR_API_TOKEN_HERE'
  probes:
    exclude:
      - Switch/ManagedSwitch
