# =============================================================================
# Clobot Monitoring Stack — 환경 변수
# 이 파일을 .env 로 복사 후 실제 값 입력
# cp .env.example .env
#
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 포함됨)
# =============================================================================

# Grafana 관리자 비밀번호
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here

# HAProxy Stats 인증 정보
HAPROXY_STATS_USER=your_haproxy_stats_user
HAPROXY_STATS_PASSWORD=your_haproxy_stats_password

# Gmail SMTP 앱 비밀번호 (Google 계정 → 보안 → 앱 비밀번호)
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# FortiGate REST API Token
# FortiGate UI → System → Administrators → REST API Admin
FORTIGATE_API_TOKEN=your_fortigate_api_token_here
