# =============================================================================
# Infrastructure Monitoring Stack — 환경 변수
# cp .env.example .env 후 실제 값 입력
# ⚠️  .env 는 절대 Git 커밋 금지 (.gitignore 포함됨)
# =============================================================================

# ── 사이트 식별 ───────────────────────────────────────────────────────────────
DATACENTER=your-datacenter          # Prometheus external_label (예: hq, aws-ap, site-a)
ENVIRONMENT=production              # production / staging / dev

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme!

# ── 알림 채널 ─────────────────────────────────────────────────────────────────
# Gmail SMTP (Critical 알람 백업용)
GMAIL_APP_PASSWORD=your_gmail_app_password

# 알림 수신 이메일
ALERT_EMAIL=infra-team@your-company.com

# ── 로드밸런서 (HAProxy Exporter 사용 시) ────────────────────────────────────
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=your_haproxy_stats_password

# ── 네트워크 장비 (FortiGate Exporter 사용 시) ───────────────────────────────
FORTIGATE_API_TOKEN=your_fortigate_api_token

# ── AWS CloudWatch (YACE Exporter 사용 시) ───────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-northeast-2
