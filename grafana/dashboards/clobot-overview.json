{
  "title": "Clobot Infra Overview",
  "uid": "clobot-overview",
  "timezone": "Asia/Seoul",
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "clobot",
    "overview"
  ],
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "nodename",
        "type": "query",
        "label": "서버",
        "datasource": {
          "type": "prometheus",
          "uid": "2Sgx-C8Nk"
        },
        "query": {
          "query": "label_values(node_uname_info{job=\"node-exporter\"}, nodename)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "🟢 온라인 인스턴스",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "count(up{job=\"node-exporter\"} == 1)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      }
    },
    {
      "id": 2,
      "title": "🔴 오프라인 인스...턴스",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "count(up{job=\"node-exporter\"} == 0) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "⚠️ 활성 알람",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "🌐 HTTP 엔드포인트 정상",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "count(probe_success{job=\"blackbox-http\"} == 1) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "🔒 SSL 최단 만료",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "min(probe_ssl_earliest_cert_expiry{job=\"blackbox-http\"} - time()) / 86400",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 21
              },
              {
                "color": "green",
                "value": 60
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 6,
      "title": "💾 가용 디스크 최소값",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "min(node_filesystem_avail_bytes{job=\"node-exporter\",mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{job=\"node-exporter\",mountpoint=\"/\",fstype!=\"tmpfs\"} * 100)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 15
              },
              {
                "color": "green",
                "value": 30
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 10,
      "title": "서버별 CPU 사용률 (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "100 - (avg by(nodename) (rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\",nodename=~\"$nodename\"}[5m])) * 100)",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 11,
      "title": "서버별 메모리 사용률 (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{job=\"node-exporter\",nodename=~\"$nodename\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\",nodename=~\"$nodename\"}) / node_memory_MemTotal_bytes{job=\"node-exporter\",nodename=~\"$nodename\"} * 100",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 20,
      "title": "인스턴스 Up/Down 상태",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "up{job=\"node-exporter\"}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "인스턴스",
              "nodename": "서버명",
              "Value": "상태"
            },
            "excludeByName": {
              "Time": true,
              "job": true,
              "role": true
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "상태"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "🟢 UP",
                        "color": "green"
                      },
                      "0": {
                        "text": "🔴 DOWN",
                        "color": "red"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 21,
      "title": "활성 알람 목록",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "alertname": "알람명",
              "severity": "심각도",
              "instance": "인스턴스",
              "category": "분류"
            },
            "excludeByName": {
              "Time": true,
              "Value": true,
              "alertstate": true,
              "__name__": true,
              "job": true
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "심각도"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "critical": {
                        "text": "🔴 CRITICAL",
                        "color": "red"
                      },
                      "warning": {
                        "text": "⚠️ WARNING",
                        "color": "yellow"
                      },
                      "info": {
                        "text": "ℹ️ INFO",
                        "color": "blue"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 30,
      "title": "HTTP 엔드포인트 가용성",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-http\"}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "URL",
              "Value": "상태"
            },
            "excludeByName": {
              "Time": true,
              "job": true
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "상태"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "🟢 정상",
                        "color": "green"
                      },
                      "0": {
                        "text": "🔴 장애",
                        "color": "red"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 31,
      "title": "SSL 인증서 만료일 (일 단위)",
      "type": "bargauge",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox-http\"} - time()) / 86400",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "min": 0,
          "max": 365,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 21
              },
              {
                "color": "green",
                "value": 60
              }
            ]
          }
        }
      }
    },
    {
      "id": 40,
      "title": "HAProxy 백엔드 상태",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "2Sgx-C8Nk"
      },
      "targets": [
        {
          "expr": "haproxy_backend_up",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "backend": "백엔드명",
              "instance": "Exporter",
              "Value": "상태"
            },
            "excludeByName": {
              "Time": true,
              "job": true
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "displayName": "상태",
                "desc": false
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "상태"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "🟢 UP",
                        "color": "green"
                      },
                      "0": {
                        "text": "🔴 DOWN",
                        "color": "red"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    }
  ]
}
