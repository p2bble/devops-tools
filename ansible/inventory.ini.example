# =============================================================================
# Ansible Inventory — 서버 목록 및 환경 변수
# cp inventory.ini.example inventory.ini 후 실제 값 입력
# ⚠️  inventory.ini (실제 IP/패스워드)는 Git 커밋 금지
# =============================================================================

# ── 서버 그룹 ─────────────────────────────────────────────────────────────────
[dev_server]
192.168.1.11   # [CUSTOMIZE] Dev 서버 IP

[stage_server]
192.168.1.12   # [CUSTOMIZE] Stage 서버 IP

[prod_server]
192.168.1.13   # [CUSTOMIZE] Prod 서버 IP (신중하게)

# ── 모니터링 에이전트 설치 대상 ───────────────────────────────────────────────
[monitoring_targets]
192.168.1.11
192.168.1.12
192.168.1.20   # [CUSTOMIZE] 모니터링 수집 대상 전체

# ── 공통 변수 ─────────────────────────────────────────────────────────────────
[all:vars]
ansible_user=your-user                             # [CUSTOMIZE] SSH 계정
ansible_password=your-password                     # [CUSTOMIZE] (키 인증 권장)
ansible_become_password=your-password

# NFS 스토리지 정보
nfs_server_path=192.168.1.100:/volume1/storage     # [CUSTOMIZE] NAS IP:경로
nfs_base_mount_path=/storage

# Docker Registry
docker_registry_url=registry.your-company.com     # [CUSTOMIZE]
docker_registry_user=deploy@your-company.com       # [CUSTOMIZE]
docker_registry_pass=                              # [CUSTOMIZE] 또는 .env에서 주입

# ── 그룹별 변수 ───────────────────────────────────────────────────────────────
[dev_server:vars]
env_type=dev
node_prefix=dev

[stage_server:vars]
env_type=stage
node_prefix=stage

[prod_server:vars]
env_type=prod
node_prefix=prod
